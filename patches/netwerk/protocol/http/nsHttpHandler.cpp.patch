@@ -660,6 +660,23 @@ nsresult nsHttpHandler::InitConnectionMgr() {
                         mBeConservativeForProxy);
 }
 
+nsresult nsHttpHandler::StoreServerCertHashes(
+    nsHttpConnectionInfo* aConnInfo, bool aNoSpdy, bool aNoHttp3,
+    nsTArray<RefPtr<nsIWebTransportHash>>&& aServerCertHashes) {
+  if (nsHttpConnectionMgr* connMgr = ConnMgr()) {
+    return connMgr->StoreServerCertHashes(aConnInfo, aNoSpdy, aNoHttp3,
+                                          std::move(aServerCertHashes));
+  }
+
+  if (HttpConnectionMgrParent* connMgrParent =
+          mConnMgr ? mConnMgr->AsHttpConnectionMgrParent() : nullptr) {
+    return connMgrParent->StoreServerCertHashes(aConnInfo, aNoSpdy, aNoHttp3,
+                                                std::move(aServerCertHashes));
+  }
+
+  return NS_ERROR_NOT_AVAILABLE;
+}
