+nsresult HttpConnectionMgrParent::StoreServerCertHashes(
+    nsHttpConnectionInfo* aConnInfo, bool aNoSpdy, bool aNoHttp3,
+    nsTArray<RefPtr<nsIWebTransportHash>>&& aServerCertHashes) {
+  NS_ENSURE_ARG_POINTER(aConnInfo);
+
+  HttpConnectionInfoCloneArgs connInfo;
+  nsHttpConnectionInfo::SerializeHttpConnectionInfo(aConnInfo, connInfo);
+
+  CopyableTArray<mozilla::ipc::WebTransportHash> serverCertHashes;
+  serverCertHashes.SetCapacity(aServerCertHashes.Length());
+  for (const auto& hash : aServerCertHashes) {
+    nsCString algorithm;
+    hash->GetAlgorithm(algorithm);
+
+    nsTArray<uint8_t> value;
+    hash->GetValue(value);
+
+    serverCertHashes.AppendElement(
+        mozilla::ipc::WebTransportHash(algorithm, value));
+  }
+
+  RefPtr<HttpConnectionMgrParent> self = this;
+  auto task = [self, connInfo{std::move(connInfo)}, aNoSpdy, aNoHttp3,
+               serverCertHashes{std::move(serverCertHashes)}]() mutable {
+    (void)self->SendStoreServerCertHashes(connInfo, aNoSpdy, aNoHttp3,
+                                          std::move(serverCertHashes));
+  };
+  gIOService->CallOrWaitForSocketProcess(std::move(task));
+  return NS_OK;
+}
